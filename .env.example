# Autodesk Platform Services Credentials
APS_CLIENT_ID="your_client_id_here"
APS_CLIENT_SECRET="your_client_secret_here"
# Autodesk User ID for the account admin — required for admin operations (project creation, user management).
# This is the internal UUID, not an email address. Find it in ACC Admin > Members.
ACC_ADMIN_ID="your_admin_user_id_here"

# Server Configuration
PORT=8000

# MCP API Key — required. All requests must include an X-API-Key header with this value.
# Generate a long random string (e.g. `python -c "import secrets; print(secrets.token_urlsafe(48))"`)
MCP_API_KEY="your_random_api_key_here"

# CORS — comma-separated list of origins allowed to connect to the MCP server.
# Set this to the specific domain(s) of your MCP client (e.g. Claude Desktop, Copilot Studio).
# Use "*" to allow all origins (not recommended in production).
ALLOWED_ORIGINS="https://your-mcp-client.example.com"

# Default Project Settings (Optional overrides)
DEFAULT_PROJECT_TIMEZONE="Europe/Amsterdam"
DEFAULT_PROJECT_ADDRESS_LINE1="123 Example Street"
DEFAULT_PROJECT_CITY="CityName"
DEFAULT_PROJECT_POSTAL_CODE="1234AB"
DEFAULT_PROJECT_COUNTRY="NL"
